# Copiá este archivo a .env y completá los valores reales
# El .env está en .gitignore — nunca se commitea

# Contraseña del usuario root de MySQL
DB_PASSWORD=change_me

# Secreto para firmar JWT — string largo y aleatorio (mínimo 32 caracteres)
JWT_SECRET=change_me_with_a_long_random_string_at_least_32_chars

# Origen(es) permitidos por CORS — dominio real en producción
# Múltiples orígenes separados por coma: https://tudominio.com,https://www.tudominio.com
CORS_ALLOWED_ORIGINS=https://tudominio.com

# Dominio para Caddy (reverse proxy + TLS automático)
DOMAIN=tudominio.com

# Credenciales del admin inicial — se crea automáticamente si no existe en la DB
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=change_me_strong_password

# GHCR image prefix para docker-compose.prod.yml
GHCR_IMAGE_PREFIX=ghcr.io/tu-usuario

# Sentry DSN para el backend (Spring Boot) — opcional, deshabilita error tracking si no está
SENTRY_DSN=

# Datos de la clínica — expuestos en GET /api/public/config (sin autenticación)
# Si no se definen, se usan los valores por defecto de application.properties
CLINIC_NOMBRE=Dental Montecaseros
CLINIC_TAGLINE=Odontología integral con atención cercana
CLINIC_DIRECCION=Monte Caseros 2687a
CLINIC_CIUDAD=Montevideo, Uruguay
CLINIC_HORARIO=Lunes a Viernes 09:00 – 18:00
CLINIC_TELEFONO=+59899572537
CLINIC_WHATSAPP=59899572537
CLINIC_EMAIL=dentalmontecaseros@gmail.com
# Texto libre para la sección "Sobre nosotros" (puede contener saltos de línea con \n)
CLINIC_NOSOTROS=

# Google Places — para mostrar reseñas en la página pública
# GOOGLE_PLACE_ID: ID del negocio en Google Maps (no es secreto, es público)
# Si no se define, la sección de reseñas no se muestra
GOOGLE_PLACE_ID=
# GOOGLE_PLACES_API_KEY: clave del servidor, NUNCA exponer al frontend
GOOGLE_PLACES_API_KEY=
